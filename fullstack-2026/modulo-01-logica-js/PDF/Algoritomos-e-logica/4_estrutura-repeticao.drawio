                <mxCell id="2PDZF1GC5zl0V-HgSjp5-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;while — “enquanto for verdadeiro”&lt;/h1&gt;&lt;p&gt;O while executa um bloco de código enquanto a condição for verdadeira.&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
