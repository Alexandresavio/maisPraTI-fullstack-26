        <mxCell id="Txasa61YcX3QvOH_ZtLe-77" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Condicional Simples.&lt;/h1&gt;&lt;div&gt;O desvio condicional simples permite executar um bloco de código caso o resultado do teste seja verdadeiro, ignorando um resultado falso.&lt;/div&gt;" vertex="1">
          <mxGeometry height="101" width="309" x="517" y="680" as="geometry" />
        </mxCell>
        <mxCell id="Txasa61YcX3QvOH_ZtLe-78" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Condicional composta&lt;/h1&gt;&lt;p&gt;O desvio condicional composto tem por finalidade tomar decisões de acordo com o resultado de uma condição (teste lógico), caso resultado seja V irá executar um bloco de instrução, se o resultado for falso irá executar outro caminho.&lt;/p&gt;" vertex="1">
          <mxGeometry height="131.5" width="320" x="932" y="751" as="geometry" />
        </mxCell>
        <mxCell id="Txasa61YcX3QvOH_ZtLe-79" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Condicional Aninhada&lt;/h1&gt;&lt;p&gt;Desvio Condicional Aninhado, que nada mais é do que o encadeamento de estruturas de decisão compostas em um algoritmo. Também chamamos a esse tipo de estrutura de Desvio Condicional Encadeado,&amp;nbsp;&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="405" x="1321.5" y="1121" as="geometry" />
        </mxCell>
        <mxCell id="Txasa61YcX3QvOH_ZtLe-80" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Estruturas condicionais" vertex="1">
